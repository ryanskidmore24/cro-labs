generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  ADMIN
  TESTER
  VIEWER
  REVIEWER
}

enum OrgRole {
  OWNER
  ADMIN
  MEMBER
  VIEWER
}

enum OrgPlan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum IntegrationType {
  GA4
  SEARCH_CONSOLE
  CLARITY
  SHOPIFY
}

enum TestStatus {
  DRAFT
  QUEUED
  RUNNING
  COMPLETED
  SHIPPED
  ARCHIVED
}

enum PrimaryKpi {
  CVR
  REVENUE
  AOV
  SUBSCRIPTION_RATE
  CUSTOM
}

enum DeviceTarget {
  ALL
  MOBILE
  DESKTOP
  TABLET
}

enum EffortEstimate {
  LOW
  MEDIUM
  HIGH
}

enum SignalType {
  HIGH_DROPOFF
  LOW_CTR
  FORM_ABANDONMENT
  RAGE_CLICK
  SLOW_LOAD
  HIGH_BOUNCE
}

enum Severity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum EventType {
  IMPRESSION
  CLICK
  CONVERSION
  FORM_SUBMIT
  SCROLL
  CUSTOM
}

enum AiModel {
  CLAUDE
  GEMINI
}

enum HypothesisStatus {
  SUGGESTED
  APPROVED
  REJECTED
  IMPLEMENTED
}

enum GuardrailMetricType {
  AOV
  CART_ABANDONMENT
  PAGE_LOAD
  REFUND_RATE
  CUSTOM
}

enum GuardrailOperator {
  GT
  LT
  GTE
  LTE
}

// ─── Models ──────────────────────────────────────────────────────────────────

model Organization {
  id                     String    @id @default(uuid()) @db.Uuid
  name                   String
  slug                   String    @unique
  publicKey              String    @unique @map("public_key")
  plan                   OrgPlan   @default(FREE)
  stripeCustomerId       String?   @unique @map("stripe_customer_id")
  stripeSubscriptionId   String?   @unique @map("stripe_subscription_id")
  subscriptionStatus     String?   @map("subscription_status")
  subscriptionPeriodEnd  DateTime? @map("subscription_period_end")
  createdAt              DateTime  @default(now()) @map("created_at")
  updatedAt              DateTime  @updatedAt @map("updated_at")

  members         OrganizationMember[]
  tests           Test[]
  integrations    Integration[]
  frictionSignals FrictionSignal[]
  auditLogs       AuditLog[]
  hypotheses      Hypothesis[]
  invites         OrgInvite[]

  @@map("organizations")
}

model OrgInvite {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  email          String
  role           OrgRole  @default(MEMBER)
  token          String   @unique
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId])
  @@index([token])
  @@map("org_invites")
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  role           OrgRole  @default(MEMBER)
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("organization_members")
}

model User {
  id                        String    @id @default(uuid()) @db.Uuid
  email                     String    @unique
  name                      String?
  role                      UserRole  @default(VIEWER)
  avatar                    String?
  passwordHash              String?   @map("password_hash")
  emailVerified             Boolean   @default(false) @map("email_verified")
  verificationToken         String?   @unique @map("verification_token")
  verificationTokenExpiresAt DateTime? @map("verification_token_expires_at")
  resetToken                String?   @unique @map("reset_token")
  resetTokenExpiresAt       DateTime? @map("reset_token_expires_at")
  googleId                  String?   @unique @map("google_id")
  createdAt                 DateTime  @default(now()) @map("created_at")
  updatedAt                 DateTime  @updatedAt @map("updated_at")

  memberships OrganizationMember[]
  tests       Test[]
  auditLogs   AuditLog[]

  @@map("users")
}

model Integration {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  type           IntegrationType
  accessToken    String          @map("access_token")
  refreshToken   String?         @map("refresh_token")
  expiresAt      DateTime?       @map("expires_at")
  metadata       Json?
  enabled        Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([type])
  @@map("integrations")
}

model Test {
  id                   String          @id @default(uuid()) @db.Uuid
  organizationId       String          @map("organization_id") @db.Uuid
  name                 String
  description          String?
  hypothesis           String?
  status               TestStatus      @default(DRAFT)
  primaryKpi           PrimaryKpi      @map("primary_kpi")
  targetUrl            String?         @map("target_url")
  deviceTarget         DeviceTarget    @default(ALL) @map("device_target")
  trafficPercent       Int             @default(100) @map("traffic_percent")
  trafficSplit         Json?           @map("traffic_split")
  audienceFilters      Json?           @map("audience_filters")
  projectedRevenueLift Float?          @map("projected_revenue_lift")
  effortEstimate       EffortEstimate? @map("effort_estimate")
  priority             Int             @default(0)
  ownerId              String          @map("owner_id") @db.Uuid
  createdAt            DateTime        @default(now()) @map("created_at")
  updatedAt            DateTime        @updatedAt @map("updated_at")
  startedAt            DateTime?       @map("started_at")
  endedAt              DateTime?       @map("ended_at")

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner            User?             @relation(fields: [ownerId], references: [id])
  variants         Variant[]
  results          TestResult[]
  hypotheses       Hypothesis[]
  events           TestEvent[]
  guardrailMetrics GuardrailMetric[]

  @@index([organizationId])
  @@index([status])
  @@index([primaryKpi])
  @@index([createdAt])
  @@map("tests")
}

model Variant {
  id            String   @id @default(uuid()) @db.Uuid
  testId        String   @map("test_id") @db.Uuid
  name          String
  isControl     Boolean  @default(false) @map("is_control")
  trafficWeight Int      @default(50) @map("traffic_weight")
  domChanges    Json?    @map("dom_changes")
  cssChanges    String?  @map("css_changes")
  jsChanges     String?  @map("js_changes")
  screenshotUrl String?  @map("screenshot_url")
  createdAt     DateTime @default(now()) @map("created_at")

  test    Test         @relation(fields: [testId], references: [id], onDelete: Cascade)
  results TestResult[]
  events  TestEvent[]

  @@index([testId])
  @@map("variants")
}

model TestResult {
  id                   String   @id @default(uuid()) @db.Uuid
  testId               String   @map("test_id") @db.Uuid
  variantId            String   @map("variant_id") @db.Uuid
  impressions          Int      @default(0)
  conversions          Int      @default(0)
  revenue              Float    @default(0)
  aov                  Float    @default(0)
  subscriptionRate     Float?   @map("subscription_rate")
  bayesianProbability  Float?   @map("bayesian_probability")
  credibleIntervalLow  Float?   @map("credible_interval_low")
  credibleIntervalHigh Float?   @map("credible_interval_high")
  liftPercent          Float?   @map("lift_percent")
  guardrailViolations  Json?    @map("guardrail_violations")
  computedAt           DateTime @default(now()) @map("computed_at")

  test    Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variantId])
  @@index([computedAt])
  @@map("test_results")
}

model Hypothesis {
  id              String           @id @default(uuid()) @db.Uuid
  organizationId  String?          @map("organization_id") @db.Uuid
  testId          String?          @map("test_id") @db.Uuid
  frictionSignal  String?          @map("friction_signal")
  suggestedChange String?          @map("suggested_change")
  predictedKpi    String?          @map("predicted_kpi")
  predictedLift   Float?           @map("predicted_lift")
  confidenceScore Float?           @map("confidence_score")
  effort          EffortEstimate?
  aiModel         AiModel?         @map("ai_model")
  evidenceData    Json?            @map("evidence_data")
  status          HypothesisStatus @default(SUGGESTED)
  createdAt       DateTime         @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  test         Test?         @relation(fields: [testId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([testId])
  @@index([status])
  @@index([aiModel])
  @@map("hypotheses")
}

model FrictionSignal {
  id             String     @id @default(uuid()) @db.Uuid
  organizationId String?    @map("organization_id") @db.Uuid
  pageUrl        String     @map("page_url")
  signalType     SignalType @map("signal_type")
  severity       Severity
  metric         Float
  baseline       Float
  detectedAt     DateTime   @default(now()) @map("detected_at")
  resolvedAt     DateTime?  @map("resolved_at")
  metadata       Json?

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([pageUrl])
  @@index([signalType])
  @@index([severity])
  @@index([detectedAt])
  @@map("friction_signals")
}

model TestEvent {
  id        String    @id @default(uuid()) @db.Uuid
  testId    String    @map("test_id") @db.Uuid
  variantId String    @map("variant_id") @db.Uuid
  visitorId String    @map("visitor_id")
  sessionId String    @map("session_id")
  eventType EventType @map("event_type")
  eventData Json?     @map("event_data")
  revenue   Float?
  pageUrl   String?   @map("page_url")
  device    String?
  source    String?
  createdAt DateTime  @default(now()) @map("created_at")

  test    Test    @relation(fields: [testId], references: [id], onDelete: Cascade)
  variant Variant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@index([variantId])
  @@index([visitorId])
  @@index([sessionId])
  @@index([eventType])
  @@index([createdAt])
  @@map("test_events")
}

model AuditLog {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String?  @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  action         String
  entityType     String   @map("entity_type")
  entityId       String   @map("entity_id")
  details        Json?
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model GuardrailMetric {
  id         String              @id @default(uuid()) @db.Uuid
  testId     String              @map("test_id") @db.Uuid
  metric     GuardrailMetricType
  threshold  Float
  operator   GuardrailOperator
  customName String?             @map("custom_name")

  test Test @relation(fields: [testId], references: [id], onDelete: Cascade)

  @@index([testId])
  @@map("guardrail_metrics")
}
